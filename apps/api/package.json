{
  "name": "@gta6-guide/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/server/index.js",
  "scripts": {
    "dev": "tsx watch --tsconfig tsconfig.json src/server/index.ts",
    "build": "tsc -p tsconfig.json && tsc-alias -p tsconfig.json",
    "start": "node dist/server/index.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "predev": "pnpm --filter @gta6-guide/shared build"
  },
  "dependencies": {
    "@gta6-guide/shared": "workspace:*",
    "bcryptjs": "2.4.3",
    "compression": "1.8.0",
    "cookie-parser": "1.4.7",
    "cors": "2.8.5",
    "dotenv": "16.6.1",
    "express": "5.1.0",
    "express-rate-limit": "7.5.1",
    "helmet": "8.1.0",
    "http-status-codes": "2.3.0",
    "jsonwebtoken": "9.0.2",
    "mongoose": "8.16.4",
    "morgan": "1.10.0",
    "pino": "9.7.0",
    "pino-http": "10.5.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "2.4.6",
    "@types/compression": "1.8.1",
    "@types/cookie-parser": "1.4.9",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.3",
    "@types/jsonwebtoken": "9.0.10",
    "@types/morgan": "1.9.10",
    "@types/node": "22.16.0",
    "pino-pretty": "13.0.0",
    "tsc-alias": "1.8.16",
    "tsx": "4.20.3",
    "typescript": "5.8.3"
  }
}
