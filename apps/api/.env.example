NODE_ENV="development"
PORT="5000"

CLIENT_URL="http://localhost:5173"
API_BASE_URL="/api/v1"

MONGODB_URI="mongodb+srv://username:password@cluster.mongodb.net/gta6guide_dev"

JWT_ACCESS_SECRET="replace-with-a-secure-access-secret"
JWT_REFRESH_SECRET="replace-with-a-secure-refresh-secret"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

COOKIE_SECRET="replace-with-a-secure-cookie-secret"
REFRESH_TOKEN_COOKIE_NAME="gta6_refresh_token"

BCRYPT_SALT_ROUNDS="12"

RATE_LIMIT_WINDOW_MS="900000"
RATE_LIMIT_MAX_REQUESTS="100"
AUTH_RATE_LIMIT_WINDOW_MS="900000"
AUTH_RATE_LIMIT_MAX_REQUESTS="20"

LOG_LEVEL="info"
