{
  "name": "@gta6-guide/shared",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./api": {
      "types": "./src/types/api.ts",
      "import": "./dist/types/api.js"
    },
    "./content": {
      "types": "./src/constants/content.ts",
      "import": "./dist/constants/content.js"
    },
    "./dto": {
      "types": "./src/types/dto.ts",
      "import": "./dist/types/dto.js"
    },
    "./pagination": {
      "types": "./src/pagination.ts",
      "import": "./dist/pagination.js"
    },
    "./roles": {
      "types": "./src/constants/roles.ts",
      "import": "./dist/constants/roles.js"
    },
    "./schemas": {
      "types": "./src/schemas/index.ts",
      "import": "./dist/schemas/index.js"
    },
    "./slug": {
      "types": "./src/utils/slug.ts",
      "import": "./dist/utils/slug.js"
    },
    "./users": {
      "types": "./src/constants/users.ts",
      "import": "./dist/constants/users.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "slugify": "1.6.6",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/node": "22.16.0",
    "typescript": "5.8.3"
  }
}
